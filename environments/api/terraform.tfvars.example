aws_region  = "ap-south-1"
project     = "gamya-couture"
environment = "api"

# Your public IP for SSH (/32) — get from https://ifconfig.me
admin_cidr = "203.0.113.10/32"
enable_ssh = true

# Optional EC2 key pair name in ap-south-1
# ec2_key_name = "my-keypair"

ec2_instance_type = "t3.micro"
api_port          = 8080
vpc_cidr          = "10.50.0.0/16"
