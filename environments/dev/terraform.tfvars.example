# Dev only — minimal API backend for Vercel (ap-south-1)
# Copy to terraform.tfvars (gitignored)

aws_region  = "ap-south-1"
environment = "dev"
project     = "gamya-couture"
owner       = "Venkat"

vpc_cidr = "10.50.0.0/16"

# Your public IP (/32) — https://ifconfig.me
admin_cidr = "203.0.113.10/32"
enable_ssh = true

ec2_instance_type = "t3.micro"
api_port          = 8080
# ec2_key_name    = "my-keypair"

# Optional admin SSH keys (cloud-init). CI deploy uses SSM — no deploy key required.
# ssh_authorized_keys = ["ssh-ed25519 AAAA... your-admin-key"]

# SSM deploy: S3 bucket + GitHub OIDC role (gvsharma/gamyaboutique)
enable_backend_ssm_deploy = true
github_backend_repository = "gvsharma/gamyaboutique"

db_name     = "gamya"
db_username = "gamya_admin"

# Cost savings: Mon–Fri 06:00–11:00; Sat 18:00–00:00; Sun 06:00–00:00 IST
enable_cost_schedule = true
schedule_timezone  = "Asia/Kolkata"

# Set false to run EC2+RDS 24/7 (e.g. demo week)
# enable_cost_schedule = false
